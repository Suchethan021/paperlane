# Copy to .env and fill in.

# Postgres. Any provider works; Neon's free tier needs no card.
# Use the POOLED connection string on serverless hosts.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Signs the session cookie. Any long random string.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="replace-me-with-32-random-bytes"

# Optional. Enables the "Summarise" action.
# Free key: https://aistudio.google.com/apikey
# Without it the app runs normally and the button is hidden.
GEMINI_API_KEY=""
